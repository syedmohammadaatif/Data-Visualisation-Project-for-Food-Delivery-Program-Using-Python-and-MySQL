import mysql.connector as mc
import matplotlib.pyplot as plt

mydb=mc.connect(host='localhost',
                user='root',
                password='aatif',
                auth_plugin='mysql_native_password',
                database='fastfoodz')

mycursor=mydb.cursor()

mycursor.execute("select Payment_Method,count(Payment_Method) as 'No_of_Users' from payment group by Payment_Method;")
result=mycursor.fetchall

Payment_Method=[]
No_of_Users=[]

for i in mycursor:
    Payment_Method.append(i[0])
    No_of_Users.append(i[1])

print('Method of Payment=',Payment_Method)
print('No. of Users=',No_of_Users)

#Visualising Data using Matplotlib

plt.bar(Payment_Method,No_of_Users,color=['blue','green'])
plt.xlabel('Method of Payment')
plt.ylabel('No. of Users')
plt.title('Payment Information')
plt.show()
